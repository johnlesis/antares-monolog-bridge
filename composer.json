{
    "name": "fatjon-lleshi/antares-monolog-bridge",
    "description": "Monolog bridge for Antares framework",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Fatjon Lleshi",
            "email": "johnlesis91@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.2",
        "monolog/monolog": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Antares\\Monolog\\": "src/"
        }
    },
    "extra": {
        "antares": {
            "providers": [
                "Antares\\Monolog\\MonologServiceProvider"
            ]
        }
    }
}